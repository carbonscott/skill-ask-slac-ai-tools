{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "policies",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "url"],
    "additionalProperties": false,
    "properties": {
      "name": {"type": "string", "minLength": 1},
      "url": {"type": "string", "format": "uri"}
    }
  }
}
